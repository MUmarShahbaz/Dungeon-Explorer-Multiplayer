[sub_resource type="GDScript" id="GDScript_b6ebu"]
script/source = "extends Node2D

func _ready() -> void:
	$Fade.fade_in()
	$\"Mobs/Skeleton Champion\".remove_from_group(\"enemies\")
	$PlayerSpawner.display_player_selector()
	var this_player = await $PlayerSpawner.player_spawned
	this_player.disable_controls = true
	var dialogue_box = DialogueBox.new()
	add_child(dialogue_box)
	await dialogue_box.begin_dialogue(dialogue_on_start)
	dialogue_box.queue_free()
	$Spawner.begin()
	this_player.disable_controls = false

func _on_to_boss_door_door_used(players) -> void:
	for this_player in players:
		this_player.global_position = Vector2(3528, -976)

func _on_from_boss_door_door_used(players) -> void:
	if get_node_or_null(\"Spawner\"): $Spawner.queue_free()
	for this_player in players:
		this_player.global_position = Vector2(3248, 384)

func _on_exit_door_door_used(_players) -> void:
	var dialogue_box = DialogueBox.new()
	add_child(dialogue_box)
	dialogue_box.begin_dialogue(dialogue_on_end)

func _process(_delta: float) -> void:
	if get_tree().get_nodes_in_group(\"enemies\").size() == 0:
		$\"Doors/To Boss\".unlock()
		$\"Doors/Exit Door\".unlock()
	else:
		$\"Doors/To Boss\".lock()
		$\"Doors/Exit Door\".lock()
	if get_node_or_null(\"Mobs/Skeleton Champion\") == null:
		$\"Doors/From Boss\".unlock()

var dialogue_on_start : Array[Dialogue] = [
	Dialogue.new(
		\"!!??\",
		load(\"res://assets/sprites/dialogues/dark queen/Aggression.png\"),
		true
	),
	Dialogue.new(
		\"WHO DARES ENTER MY DUNGEON??\",
		load(\"res://assets/sprites/dialogues/dark queen/Aggression.png\"),
		true
	),
	Dialogue.new(
		\"Hmmmm........\\nYou look like you could take a hit or two.....\",
		load(\"res://assets/sprites/dialogues/dark queen/Calm.png\"),
		true
	),
	Dialogue.new(
		\"Very well.......\\nYou will be my entertainment today!\",
		load(\"res://assets/sprites/dialogues/dark queen/Talk.png\"),
		true
	),
	Dialogue.new(
		\"Up ahead is an infinitely growing number of my skeleton soldiers.\",
		load(\"res://assets/sprites/dialogues/dark queen/Talk.png\"),
		true
	),
	Dialogue.new(
		\"The only way to stop more from spawning is to defeat the champion.\",
		load(\"res://assets/sprites/dialogues/dark queen/Talk.png\"),
		true
	),
	Dialogue.new(
		\"The door to the champion only unlocks for a brief moment\\nwhen there are no skeleton soldiers.\",
		load(\"res://assets/sprites/dialogues/dark queen/Talk.png\"),
		true
	),
	Dialogue.new(
		\"Only after all foes are dead, you may leave through where you came.\",
		load(\"res://assets/sprites/dialogues/dark queen/Talk.png\"),
		true
	),
	Dialogue.new(
		\"In here you will be denied even death!\\nSo you may suffer in an endless battle.\",
		load(\"res://assets/sprites/dialogues/dark queen/Talk.png\"),
		true
	),
	Dialogue.new(
		\"What a horrible fate.........\",
		load(\"res://assets/sprites/dialogues/dark queen/Sadness.png\"),
		true
	),
]

var dialogue_on_end : Array[Dialogue] = [
		Dialogue.new(
		\"Impressive.....\",
		load(\"res://assets/sprites/dialogues/dark queen/Talk.png\"),
		true
	),
]
"

