[sub_resource type="GDScript" id="GDScript_pbymd"]
script/source = "extends Node2D

func _ready() -> void:
	$Fade.fade_in()
	$PlayerSpawner.display_player_selector()
	$\"Green Slimes/Spawner\".begin()
	$\"Blue Slimes/Spawner\".begin()
	$\"Red Slimes/Spawner\".begin()
	$Hellhounds/Spawner.begin()
	$Cereberus/Spawner.begin()
"

[sub_resource type="GDScript" id="GDScript_n8b30"]
script/source = "extends Node2D

func _on_green_slimes_wave_finished() -> void:
	$door6.unlock()

func _on_blue_slimes_wave_finished() -> void:
	$door7.unlock()
	$door5.unlock()

func _on_red_slimes_wave_finished() -> void:
	$door9.unlock()

func _on_goblins_wave_finished() -> void:
	$door11.unlock()

func _on_goblin_champion_wave_finished() -> void:
	$door14.unlock()

func _on_hellhounds_wave_finished() -> void:
	$door12.unlock()

func _on_cereberus_wave_finished() -> void:
	$door15.unlock()

func _on_door_1_door_opened(players: Array) -> void:
	for player in players: player.global_position = $door2.global_position

func _on_door_3_door_opened(players: Array) -> void:
	$\"../PlayerSpawner\".global_position = $door4.global_position
	for player in players: player.global_position = $door4.global_position

func _on_door_5_door_opened(players: Array) -> void:
	for player in players : player.global_position = $door8.global_position

func _on_door_6_door_opened(players: Array) -> void:
	for player in players : player.global_position = $door7.global_position

func _on_door_7_door_opened(players: Array) -> void:
	for player in players : player.global_position = $door6.global_position

func _on_door_9_door_opened(players: Array) -> void:
	$\"../PlayerSpawner\".global_position = $door10.global_position
	for player in players : player.global_position = $door10.global_position

func _on_door_11_door_opened(players: Array) -> void:
	for player in players : player.global_position = $door14.global_position

func _on_door_12_door_opened(players: Array) -> void:
	for player in players : player.global_position = $door15.global_position

func _on_door_13_door_opened(players: Array) -> void:
	pass # Replace with function body.

func _on_door_14_door_opened(players: Array) -> void:
	for player in players : player.global_position = $door11.global_position
	if $door15.state == $door15.door_state.opened: $door13.unlock()

func _on_door_15_door_opened(players: Array) -> void:
	for player in players : player.global_position = $door12.global_position
	if $door14.state == $door14.door_state.opened: $door13.unlock()
"

