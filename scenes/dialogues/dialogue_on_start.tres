[sub_resource type="Resource" id="Resource_hslqp"]
script = ExtResource("1_qg8lu")
Text = "Up ahead is an infinitely growing number of
my skeleton soldiers."
Sprite = ExtResource("4_1npgm")
Right_Side = true
metadata/_custom_type_script = "uid://86nuwqny3eip"

[sub_resource type="Resource" id="Resource_tgm7k"]
script = ExtResource("1_qg8lu")
Text = "The only way to stop more from spawning is to
defeat the champion."
Sprite = ExtResource("4_1npgm")
Right_Side = true
metadata/_custom_type_script = "uid://86nuwqny3eip"

[sub_resource type="Resource" id="Resource_gn7ra"]
script = ExtResource("1_qg8lu")
Text = "The door to the champion only unlocks for a brief moment
when there are no skeleton soldiers."
Sprite = ExtResource("4_1npgm")
Right_Side = true
metadata/_custom_type_script = "uid://86nuwqny3eip"

[sub_resource type="Resource" id="Resource_g8f2c"]
script = ExtResource("1_qg8lu")
Text = "Only after all foes are dead,
you may leave through where you came."
Sprite = ExtResource("4_1npgm")
Right_Side = true
metadata/_custom_type_script = "uid://86nuwqny3eip"

[sub_resource type="Resource" id="Resource_wa0oq"]
script = ExtResource("1_qg8lu")
Text = "In here you will be denied even death!
So you may suffer in an endless battle."
