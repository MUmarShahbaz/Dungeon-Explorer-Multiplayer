[sub_resource type="GDScript" id="GDScript_oo0fn"]
script/source = "extends CanvasLayer

var player : Player
var avatar : AtlasTexture
var multiplayer_id : int

func _ready() -> void:
	$\"Control/Player/Avatar\".texture = avatar
	$\"Control/Minimap Container/Minimap\".world_2d = get_tree().root.world_2d
	if multiplayer_id: player = get_tree().current_scene.get_node(str(multiplayer_id))

func _physics_process(_delta: float) -> void:
	if player:
		$\"Control/Player/HP_SP/HP\".value = (player.HP_Current / player.HP_Health_Points)*100
		$\"Control/Player/HP_SP/SP\".value = player.SP_Special_Points
		$Control/Player/Potions/Health/Count.text = str(player.ITM_Healing_Potions)
		$Control/Player/Potions/Boost/Count.text = str(player.ITM_Booster_Potions)
		$\"Control/Minimap Container/Minimap/Camera2D\".position = player.position
	else: queue_free()
"

