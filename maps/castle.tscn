[gd_scene format=4 uid="uid://d3sjuw2xon2v4"]

[ext_resource type="TileSet" uid="uid://kftyecbd1cvf" path="res://assets/tilemap/royal castle/castle outdoors.tres" id="1_wnf2b"]
[ext_resource type="Script" uid="uid://b666ndns0368d" path="res://scenes/player_spawner/player_spawner.gd" id="2_wnf2b"]

[sub_resource type="GDScript" id="GDScript_yhcpw"]
script/source = "extends Node2D

@export var player_spawner : PlayerSpawner

func _ready() -> void:
	player_spawner.player_spawned.connect(_on_player_spawned)
	###
	$PlayerSpawner.display_player_selector()

func _on_player_spawned(player: Player, _death_count: int) -> void:
	await player.entity_created
	await get_tree().physics_frame
	var player_cam : CAM = player.get_children().filter(func (x): return x is CAM)[0]
	var hud_cam : Camera2D = player_spawner.my_hud.get_node(\"Control/Minimap Container/Minimap/Camera2D\")
	hud_cam.zoom = Vector2(0.5, 0.5)
	hud_cam.limit_top = -190
	player_cam.limit_top = -190
	hud_cam.limit_bottom = 300
	player_cam.limit_bottom = 300

func _physics_process(_delta: float) -> void:
	if player_spawner.my_player:
		var my_collider : CollisionShape2D = player_spawner.my_player.get_children().filter(func (x): return x is CollisionShape2D)[0]
		var my_feet_coords : float =my_collider.shape.get_rect().end.y + player_spawner.my_player.global_position.y
		if my_feet_coords < -25:
			while player_spawner.my_player.velocity.y < 0:
				await get_tree().physics_frame
			$\"Tilemap/Balcony\".z_index = 10
		if my_feet_coords > -10:
			$\"Tilemap/Balcony\".z_index = 0
"

