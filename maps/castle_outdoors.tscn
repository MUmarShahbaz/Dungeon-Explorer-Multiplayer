[sub_resource type="GDScript" id="GDScript_yhcpw"]
script/source = "extends Node2D

@export var player_spawner : PlayerSpawner

func _ready() -> void:
	player_spawner.player_spawned.connect(func (_x,_y): QuickScripts.clamp_camera(-1036.5, 3110, -190, 300, INF, 0.5))

func entity_z_index(entity : Entity):
	var global_bounds = QuickScripts.get_bounds(entity).slice(4, 8)
	if global_bounds[3] < -13:
		while entity.velocity.y < 0:
			await get_tree().physics_frame
		entity.z_index = -1
	else:
		if global_bounds[0] > 1386:
			if global_bounds[2] < -4.5: entity.z_index = 0
			elif global_bounds[3] < 118:
				entity.z_index = -2
				entity.get_children().filter(func (x): return x is LightOccluder2D)[0].hide()
			else:
				entity.z_index = 0
				entity.get_children().filter(func (x): return x is LightOccluder2D)[0].show()
		else:
			entity.z_index = 0
"

