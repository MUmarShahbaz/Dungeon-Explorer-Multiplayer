[sub_resource type="GDScript" id="GDScript_tt30a"]
script/source = "extends CanvasLayer

var lvl1 = load(\"res://lvl/enter_the_dungeon.tscn\")

@onready var Gamepad := $Menu/Controls/Gamepad
@onready var Keyboard := $Menu/Controls/Keyboard

func _ready() -> void:
	$Menu/Main/Play.grab_focus()

func _physics_process(delta: float) -> void:
	if Input.is_joy_known(0):
		Gamepad.show()
		Keyboard.hide()
	else:
		Gamepad.hide()
		Keyboard.show()

@onready var Main := $Menu/Main
@onready var Controls := $Menu/Controls
@onready var Missions := $Menu/Missions
@onready var Stats := $\"Menu/Entity Stats\"
@onready var Back := $Menu/Back

enum states {Main, Controls, Missions, Stats}

func change_state(new_state : states):
	if new_state == states.Main:
		$Menu/Main/Play.grab_focus()
		Controls.hide()
		Missions.hide()
		Stats.hide()
		Back.hide()
	else:
		Back.show()
		Back.grab_focus()
		match new_state:
			states.Controls: Controls.show()
			states.Missions: Missions.show()
			states.Stats: Stats.show()

func _on_back_pressed() -> void:
	change_state(states.Main)

func _on_controls_pressed() -> void:
	change_state(states.Controls)

func _on_missions_pressed() -> void:
	change_state(states.Missions)

func _on_entity_stats_pressed() -> void:
	change_state(states.Stats)

func _on_play_pressed() -> void:
	await $Fade.fade_out()
	get_tree().change_scene_to_packed(lvl1)
"

